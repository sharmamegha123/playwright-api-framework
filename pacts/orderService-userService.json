{
  "consumer": {
    "name": "orderService"
  },
  "interactions": [
    {
      "description": "A request to get user with id 2",
      "providerStates": [
        {
          "name": "User with id 2 exist"
        }
      ],
      "request": {
        "method": "GET",
        "path": "/users/2"
      },
      "response": {
        "body": {
          "data": {
            "email": "Janet@example.com",
            "first_name": "Janet",
            "id": 2
          }
        },
        "headers": {
          "Content-Type": "application/json"
        },
        "matchingRules": {
          "body": {
            "$.data.email": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.data.first_name": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.data.id": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            }
          }
        },
        "status": 200
      }
    }
  ],
  "metadata": {
    "pact-js": {
      "version": "17.0.1"
    },
    "pactRust": {
      "ffi": "0.5.4",
      "models": "1.3.11"
    },
    "pactSpecification": {
      "version": "3.0.0"
    }
  },
  "provider": {
    "name": "userService"
  }
}